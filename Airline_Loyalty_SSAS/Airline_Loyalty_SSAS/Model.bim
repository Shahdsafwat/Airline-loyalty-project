          },
          {
            "name": "Dollar_Cost_Points_Redeemed",
            "dataType": "double",
            "sourceColumn": "Dollar_Cost_Points_Redeemed",
            "sourceProviderType": "Numeric"
          },
          {
            "name": "Enrollment_Year_KEY",
            "dataType": "int64",
            "sourceColumn": "Enrollment_Year_KEY",
            "sourceProviderType": "Integer"
          },
          {
            "name": "Enrollment_Month_KEY",
            "dataType": "int64",
            "sourceColumn": "Enrollment_Month_KEY",
            "sourceProviderType": "Integer"
          },
          {
            "name": "Cancellation_Year_KEY",
            "dataType": "int64",
            "sourceColumn": "Cancellation_Year_KEY",
            "sourceProviderType": "Integer"
          },
          {
            "name": "Cancellation_Month_KEY",
            "dataType": "int64",
            "sourceColumn": "Cancellation_Month_KEY",
            "sourceProviderType": "Integer"
          },
          {
            "type": "calculated",
            "name": "Customer_Status",
            "dataType": "string",
            "isDataTypeInferred": true,
            "expression": [
              "",
              "IF(",
              "    ISBLANK(Fact_Loyalty[Cancellation_Year_KEY]),",
              "    \"Active\",",
              "    \"Cancelled\"",
              ")"
            ]
          }
        ],
        "partitions": [
          {
            "name": "Fact_Loyalty",
            "dataView": "full",
            "source": {
              "type": "query",
              "query": " \t\t\t\tSELECT [dbo].[Fact_Loyalty].*   FROM [dbo].[Fact_Loyalty] ",
              "dataSource": "SqlServer DESKTOP-EEQM3AQ DWH_Airline_Loyalty"
            }
          }
        ],
        "measures": [
          {
            "name": "Total Distance",
            "expression": "SUM([Distance])"
          },
          {
            "name": "Total Flights",
            "expression": "SUM([Total_Flights])"
          },
          {
            "name": "customer count",
            "expression": "DISTINCTCOUNT([Loyalty_Number])"
          },
          {
            "name": "Maximum of CLV",
            "expression": "MAX([CLV])"
          },
          {
            "name": "Total Points_Accumulated",
            "expression": "SUM([Points_Accumulated])"
          },
          {
            "name": "Total Points_Redeemed",
            "expression": "SUM([Points_Redeemed])"
          },
          {
            "name": "Maximum of Distance",
            "expression": "MAX([Distance])"
          },
          {
            "name": "Maximum of Points_Accumulated",
            "expression": "MAX([Points_Accumulated])"
          },
          {
            "name": "Total  Dollar_Cost_Points_Redeemed",
            "expression": "SUM([Dollar_Cost_Points_Redeemed])"
          },
          {
            "name": "Redemption Rate",
            "expression": "DIVIDE([Total Points_Redeemed],[Total Points_Accumulated])"
          },
          {
            "name": "Avg Flights Per Customer",
            "expression": [
              "",
              "DIVIDE(",
              "    [Total Flights],",
              "    [Customer Count]",
              ")"
            ]
          },
          {
            "name": "Total CLV",
            "expression": [
              " ",
              "SUMX(",
              "    VALUES(Fact_Loyalty[Loyalty_Number]),",
              "    CALCULATE(MAX(Fact_Loyalty[CLV]))",
              ")"
            ]
          },
          {
            "name": "Avg CLV",
            "expression": [
              " ",
              "DIVIDE(",
              "    [Total CLV],",
              "    [customer count],",
              "    0",
              ")"
            ]
          },
          {
            "name": "Churn Rate",
            "expression": [
              " ",
              "DIVIDE(",
              "    CALCULATE(",
              "        DISTINCTCOUNT(Fact_Loyalty[Loyalty_Number]),",
              "        NOT ISBLANK(Fact_Loyalty[Cancellation_Year_KEY])",
              "    ),",
              "    [customer count],",
              "    0",
              ")"
            ]
          },
          {
            "name": "Active Customers",
            "expression": [
              " ",
              "CALCULATE(",
              "    DISTINCTCOUNT(Fact_Loyalty[Loyalty_Number]),",
              "    ISBLANK(Fact_Loyalty[Cancellation_Year_KEY])",
              ")",
              ""
            ]
          },
          {
            "name": "Count of Loyalty_Number",
            "expression": "COUNTA([Loyalty_Number])"
          },
          {
            "name": "Cancelled Customers",
            "expression": [
              "",
              "CALCULATE(",
              "    DISTINCTCOUNT(Fact_Loyalty[Loyalty_Number]),",
              "    NOT(ISBLANK(Fact_Loyalty[Cancellation_Year_KEY]))",
              ")"
            ]
          },
          {
            "name": "Average of Total_Flights",
            "expression": "AVERAGE([Total_Flights])"
          },
          {
            "name": "Active Customers_month",
            "expression": [
              " ",
              "CALCULATE(",
              "    DISTINCTCOUNT(Fact_Loyalty[Loyalty_Number]),",
              "    ISBLANK(Fact_Loyalty[Cancellation_Month_KEY])",
              ")"
            ]
          }
        ],
